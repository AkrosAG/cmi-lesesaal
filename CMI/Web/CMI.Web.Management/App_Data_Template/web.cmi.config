<cmiSettings>
  <add key="sqlConnectionString" value="@@CMI.SqlServer.DbConnectionSetting.ConnectionString@@" />

  <add key="sftpLicenseKey" value="@@cmiSettings.sftpLicenseKey@@" />

  <add key="clientDefaultPath" value="/client/" />
  <add key="indexPagePath" value="~/client/index.html" />
  
  <add key="configDirectory" value="~/App_Data" />
  <add key="clientConfigDirectory" value="~/client/config" />

  <add key="injectTranslations" value="true" />
  <add key="injectSettings" value="false" />
  <add key="injectModelData" value="false" />
  
  <add key="enableIndexPageCaching" value="false" />
  
  <add key="enableTranslationsCaching" value="false" />
  <add key="enableSettingsCaching" value="false" />
  <add key="enableModelDataCaching" value="false" />
    
  <add key="logoutUrl" value="https://www.recherche.bar.admin.ch/auth/saml2/slo" />
  <add key="publicClientUrl" value="@@CMI.Web.Frontend.AppData_Template.PublicClientUrl@@/" />
  <add key="managementAuthReturnUrl" value="@@CMI.Web.Frontend.AppData_Template.ManagementClientUrl@@/#/auth/success" />

  <add key="managementLogoutReturnUrl" value="@@CMI.Web.Management.AppData_Template.ManagementLogoutReturnUrl@@" />

  <add key="rabbitMqManagementUri" value="http://localhost:15672/" />

  <add key="serviceHeartbeatRequestTimeout" value="5" />
  <add key="serviceTestRequestTimeout" value="15" />
  <add key="serviceRequestTimeToLive" value="5" />
  <add key="cookieExpireTimeInMinutes" value="60" />

  <add key="monitoringExcludedService" value="@@MonitoringExcludedService@@" />
  <add key="additionalInternalUsers" value="@@CMI.Web.Management.AppData_Template.AdditionalInternalUsers@@" />
  <add key="AsposeLicense" value="@@CMI.Utilities.License.Properties.Settings.AsposeLicense@@" />	
</cmiSettings>
