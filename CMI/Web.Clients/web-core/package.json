    "@types/node": "^18.11.2",
    "@typescript-eslint/eslint-plugin": "^5.40.1",
    "@typescript-eslint/parser": "^5.40.1",
    "codelyzer": "^6.0.2",
    "file-saver": "2.0.5",
    "jasmine-core": "~4.0.1",
    "jasmine-spec-reporter": "~7.0.0",
