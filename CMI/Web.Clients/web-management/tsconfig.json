{
	"compileOnSave": false,
  "compilerOptions": {
    "importHelpers": true,
    "outDir": "./dist/out-tsc",
    "esModuleInterop": true,
		"sourceMap": true,
		"declaration": false,
		"moduleResolution": "node",
		"experimentalDecorators": true,
		"target": "ES2022",
		"typeRoots": [
			"node_modules/@types"
		],
		"lib": [
			"dom",
			"es2020"
		],
		"noUnusedLocals": true,
		"noUnusedParameters": false,
		"baseUrl": "./",
		"module": "ES2020"
	},
	"angularCompilerOptions": {
		"preserveWhitespaces": true
	}
}
