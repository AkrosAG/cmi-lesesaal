<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <sectionGroup name="applicationSettings" type="System.Configuration.ApplicationSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" >
      <section name="CMI.Access.Repository.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
    </sectionGroup>
  </configSections>
  <runtime>
  </runtime>
<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/></startup><applicationSettings>
    <CMI.Access.Repository.Properties.Settings>
      <setting name="RepositoryServiceUrl" serializeAs="String">
        <value>@@CMI.Access.Repository.Properties.Settings.RepositoryServiceUrl@@</value>
      </setting>
      <setting name="ConnectionMode" serializeAs="String">
        <value>atom</value>
      </setting>
      <setting name="FixityAlgorithmRefElementName" serializeAs="String">
        <value>Fixity Algorithm Ref</value>
      </setting>
      <setting name="FixityValueElementName" serializeAs="String">
        <value>Fixity Value</value>
      </setting>
      <setting name="RepositoryUser" serializeAs="String">
        <value>@@CMI.Access.Repository.Properties.Settings.RepositoryUser@@</value>
      </setting>
      <setting name="RepositoryPassword" serializeAs="String">
        <value>@@CMI.Access.Repository.Properties.Settings.RepositoryPassword@@</value>
      </setting>
      <setting name="RepositoryDirectoryUser" serializeAs="String">
        <value>@@CMI.Access.Repository.Properties.Settings.RepositoryDirectoryUser@@</value>
      </setting>
      <setting name="RepositoryDirectoryPassword" serializeAs="String">
        <value>@@CMI.Access.Repository.Properties.Settings.RepositoryDirectoryPassword@@</value>
      </setting>
      <setting name="RepositoryExportIEUrl" serializeAs="String">
        <value>@@CMI.Access.Repository.Properties.Settings.RepositoryExportIEUrl@@</value>
      </setting>
      <setting name="RepositoryCommandTimeout" serializeAs="String">
        <value>0</value>
      </setting>
      <setting name="RepositoryTimeout" serializeAs="String">
        <value>0</value>
      </setting>
      <setting name="RepositoryDirectory" serializeAs="String">
        <value>@@CMI.Access.Repository.Properties.Settings.RepositoryDirectory@@</value>
      </setting>
      <setting name="RepositoryDomain" serializeAs="String">
        <value>@@CMI.Access.Repository.Properties.Settings.RepositoryDomain@@</value>
      </setting>
    </CMI.Access.Repository.Properties.Settings>
  </applicationSettings>
</configuration>
